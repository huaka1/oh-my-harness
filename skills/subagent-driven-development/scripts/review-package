#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: review-package BASE HEAD|WORKTREE [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2

git rev-parse --verify --quiet "$base" >/dev/null || { echo "bad BASE: $base" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$(git rev-parse --git-path sdd)
  mkdir -p "$dir"
  dir=$(cd "$dir" && pwd)
  if [ "$head" = "WORKTREE" ]; then
    out="$dir/review-$(git rev-parse --short "$base")..worktree.diff"
  else
    git rev-parse --verify --quiet "$head" >/dev/null || { echo "bad HEAD: $head" >&2; exit 2; }
    out="$dir/review-$(git rev-parse --short "$base")..$(git rev-parse --short "$head").diff"
  fi
fi

{
  echo "# Review package: ${base}..${head}"
  echo
  echo "## Commits"
  if [ "$head" = "WORKTREE" ]; then
    git log --oneline "${base}..HEAD" || true
  else
    git log --oneline "${base}..${head}"
  fi
  echo
  echo "## Files changed"
  if [ "$head" = "WORKTREE" ]; then
    git diff --stat "$base"
  else
    git diff --stat "${base}..${head}"
  fi
  echo
  echo "## Diff"
  if [ "$head" = "WORKTREE" ]; then
    git diff -U10 "$base"
  else
    git diff -U10 "${base}..${head}"
  fi
} > "$out"

echo "wrote ${out}: $(wc -c < "$out" | tr -d ' ') bytes"
